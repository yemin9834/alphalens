# AlphaLens - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================
# AWS
# ============================================================
AWS_ACCOUNT_ID=123456789012
DEFAULT_AWS_REGION=us-east-1

# ============================================================
# LLM provider (Guide 4+ local dev)
# ============================================================
# bedrock = AWS Nova Pro (course default) | openai = OpenAI API
LLM_PROVIDER=bedrock
BEDROCK_MODEL_ID=us.amazon.nova-pro-v1:0
BEDROCK_REGION=us-west-2
OPENAI_API_KEY=
OPENAI_MODEL_ID=gpt-4.1-mini

# ============================================================
# Database (after terraform/1_database)
# ============================================================
AURORA_CLUSTER_ARN=arn:aws:rds:us-east-1:123456789012:cluster:alphalens-aurora-cluster
AURORA_SECRET_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:alphalens-aurora-credentials-xxxxx
DATABASE_NAME=alphalens

# ============================================================
# Agents (after terraform/2_agents)
# ============================================================
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/alphalens-analysis-jobs
ORCHESTRATOR_FUNCTION=alphalens-orchestrator
DISCOVERY_FUNCTION=alphalens-discovery
# Live LLM+MCP service URL (after terraform/3_discovery deploy)
DISCOVERY_SERVICE_URL=
DISCOVERY_HTTP_TIMEOUT=300
# Phase 2 deep research (async = SQS worker after discovery; inline = Phase 1 stream)
DEEP_RESEARCH_MODE=async
DEEP_RESEARCH_ENABLED=true
DEEP_RESEARCH_MAX_CANDIDATES=5
DEEP_RESEARCH_QUEUE_URL=
VALIDATOR_FUNCTION=alphalens-validator
ANALYST_FUNCTION=alphalens-analyst
PORTFOLIO_FUNCTION=alphalens-portfolio
QA_FUNCTION=alphalens-qa
# Q&A streaming — alphalens-qa Function URL (local API proxies here)
# QA_SERVICE_URL=https://xxxxxxxx.lambda-url.us-east-1.on.aws
# Or local QA server: QA_SERVICE_URL=http://localhost:8001

# ============================================================
# External APIs
# ============================================================
BRAVE_API_KEY=
TAVILY_API_KEY=
ALPHA_VANTAGE_API_KEY=
FRED_API_KEY=

# ============================================================
# Frontend / Auth (after terraform/4_frontend)
# ============================================================
# When CLERK_JWKS_URL is set, API requires Bearer JWT on /api/* routes.
# When unset, API uses DEMO_USER_ID for all requests (local dev default).
CLERK_JWKS_URL=
CLERK_ISSUER=
DEMO_USER_ID=demo-user
CORS_ORIGINS=http://localhost:3000

# ============================================================
# Local development
# ============================================================
MOCK_LAMBDAS=true
# Run portfolio step in-process while other agents use Lambdas (local metric changes).
USE_LOCAL_PORTFOLIO=false

# LLM agent modes (Guide 4+) — keep false for MVP deterministic Lambdas
USE_LLM_ORCHESTRATION=false
USE_LIVE_DISCOVERY=false
DISCOVERY_MCP_CONFIGURED=false
DISCOVERY_PLAYWRIGHT_MCP=true
DISCOVERY_MCP_TIMEOUT=120
DISCOVERY_MAX_TURNS=15
USE_LLM_PORTFOLIO=false
# Narrative-only hybrid (legacy USE_LLM_PORTFOLIO=true maps to the same behavior)
USE_LLM_PORTFOLIO_NARRATIVE=false
USE_LLM_QA=false
USE_LLM_ANALYST_NARRATIVE=false
USE_LLM_VALIDATOR_NARRATIVE=false
# Set VALIDATOR_SKIP_MARKET_LOOKUP=true to skip yfinance in validator (offline tests)
VALIDATOR_SKIP_MARKET_LOOKUP=false
# Q&A invokes alphalens-qa Lambda by default (even with MOCK_LAMBDAS=true).
# Set MOCK_QA=true for offline keyword answers without calling AWS.
MOCK_QA=false
MCP_LOGGING=false
